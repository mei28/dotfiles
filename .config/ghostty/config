font-family = "Hack Nerd Font Mono"
font-family = "UDEV Gothic JPDOC"
font-size = 14
theme = "kanagawabones"
window-padding-x = 10
window-padding-y = 10
window-padding-balance = true
background-opacity = 0.8
background-blur-radius = 20
macos-titlebar-style = transparent

# OSC 52: write -> yank (nvim) lands in the local clipboard.
# (WezTerm allowed this by default; Ghostty/cmux requires it explicitly.)
# read is denied: nvim dropped OSC52 paste (58ac158) — paste goes through
# the terminal's native bracketed paste, and allowing read would let any
# remote program exfiltrate the local clipboard.
clipboard-write = allow
clipboard-read = deny
