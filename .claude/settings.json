{
  "alwaysThinkingEnabled": true,
  "editorMode": "normal",
  "effortLevel": "xhigh",
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "feedbackSurveyState": {
    "lastShownTime": 1754308736953
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "$HOME/dotfiles/.claude/hooks/wezterm-state.sh thinking",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "$HOME/dotfiles/.claude/hooks/wezterm-state.sh thinking",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "$HOME/dotfiles/.claude/hooks/wezterm-state.sh executing",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "$HOME/dotfiles/.claude/hooks/wezterm-state.sh",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "$HOME/dotfiles/.claude/hooks/wezterm-state.sh idle",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bash '/home/ubuntu/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "$HOME/dotfiles/.claude/hooks/wezterm-state.sh idle",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "command": "$HOME/dotfiles/.claude/hooks/wezterm-state.sh idle",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "$HOME/dotfiles/.claude/hooks/wezterm-state.sh thinking",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "model": "sonnet",
  "statusLine": {
    "command": "$HOME/dotfiles/.claude/statusline.sh",
    "type": "command"
  },
  "verbose": true
}